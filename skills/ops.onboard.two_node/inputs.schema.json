{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ops.onboard.two_node inputs",
  "type": "object",
  "required": [
    "node_a_asset_id",
    "node_b_asset_id"
  ],
  "properties": {
    "node_a_asset_id": {
      "type": "string",
      "description": "First asset identifier"
    },
    "node_b_asset_id": {
      "type": "string",
      "description": "Second asset identifier"
    },
    "ssh_username": {
      "type": "string"
    },
    "ssh_port": {
      "type": "integer",
      "default": 22
    },
    "install_subagent": {
      "type": "boolean",
      "default": false
    },
    "package_manager_hint": {
      "type": "string",
      "enum": [
        "apt",
        "dnf",
        "yum",
        "apk",
        "unknown"
      ]
    },
    "internal_cidr": {
      "type": "string"
    }
  }
}