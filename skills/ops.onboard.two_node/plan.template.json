{
  "skill_id": "ops.onboard.two_node",
  "goal": "Onboard two assets into ChassisClaw management scope",
  "jobs": [
    {
      "id": "check_assets_exist",
      "type": "precheck",
      "description": "Verify both assets are registered"
    },
    {
      "id": "probe_node_a",
      "type": "probe",
      "target_input": "node_a_asset_id",
      "description": "Collect health and capability facts from node A"
    },
    {
      "id": "probe_node_b",
      "type": "probe",
      "target_input": "node_b_asset_id",
      "description": "Collect health and capability facts from node B"
    },
    {
      "id": "decide_subagent_install",
      "type": "decision",
      "description": "Determine whether subagent installation is required and approved"
    },
    {
      "id": "install_subagent",
      "type": "install",
      "description": "Install or prepare subagent bootstrap on assets that require approval"
    },
    {
      "id": "report_summary",
      "type": "report",
      "description": "Summarize onboarding readiness, blockers, and next actions"
    }
  ],
  "expected_artifacts": [
    "node_a_probe_result.json",
    "node_b_probe_result.json",
    "install_subagent_plan.json",
    "onboarding_summary.json"
  ]
}